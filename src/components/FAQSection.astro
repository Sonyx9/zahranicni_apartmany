---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;
---

<section class="faq-section" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="faq-heading">Často kladené otázky</h2>
  <dl class="faq-list">
    {faqs.map((faq) => (
      <div class="faq-item">
        <dt class="faq-question">{faq.question}</dt>
        <dd class="faq-answer">{faq.answer}</dd>
      </div>
    ))}
  </dl>
</section>

<style>
  .faq-section {
    padding: var(--spacing-section) 0;
    background: var(--color-ivory);
  }

  .faq-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 400;
    color: var(--color-navy);
    margin: 0 0 4rem 0;
  }

  .faq-list {
    margin: 0;
    padding: 0;
  }

  .faq-item {
    margin-bottom: 3rem;
  }

  .faq-item:last-child {
    margin-bottom: 0;
  }

  .faq-question {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-navy);
    margin: 0 0 1rem 0;
  }

  .faq-answer {
    margin: 0;
    color: var(--color-slate);
    line-height: 1.6;
    font-size: 1.125rem;
  }

  @media (max-width: 768px) {
    .faq-section {
      padding: var(--spacing-section-mobile) 0;
    }

    .faq-item {
      margin-bottom: 2.5rem;
    }
  }
</style>

