---
import type { Offer } from '../lib/data';

interface Props {
  offer: Offer;
}

const { offer } = Astro.props;
---

<a 
  href={offer.url} 
  rel="noopener nofollow sponsored"
  class="offer-card offer-card-link-wrap"
>
  <div class="offer-card-image">
    <img 
      src={offer.image} 
      alt="Ilustrační fotografie nemovitosti u moře"
      loading="lazy"
    />
  </div>
  <div class="offer-card-content">
    <h3 class="offer-card-title">{offer.title}</h3>
    <p class="offer-card-price price">{offer.price}</p>
    <span class="offer-card-link">
      Prohlédnout detail nemovitosti
    </span>
  </div>
</a>

<style>
  .offer-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .offer-card:hover {
    text-decoration: none;
  }

  .offer-card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-ivory);
  }

  .offer-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .offer-card-content {
    padding: 2rem 0 0 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    gap: 0.75rem;
  }
  .offer-card-link {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .offer-card-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-navy);
    margin: 0;
    line-height: 1.3;
  }

  .offer-card-price {
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-slate);
    margin: 0;
  }

  .offer-card-link {
    color: var(--color-sand);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
    margin-top: 0.5rem;
  }

  .offer-card-link:hover,
  .offer-card-link:focus {
    color: var(--color-navy);
  }

  .offer-card-link:focus {
    outline: 2px solid var(--color-sand);
    outline-offset: 2px;
  }
</style>

