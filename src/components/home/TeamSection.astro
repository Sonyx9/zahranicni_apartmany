---
type Member = { name: string; role: string; image: string; slug: string };
type Props = { members: Member[] };
const { members } = Astro.props;
const base = import.meta.env.BASE_URL;
const baseNorm = base.endsWith('/') ? base.slice(0, -1) : base;
const basePath = base.endsWith('/') ? base : `${base}/`;

function getImagePath(img: string) {
  if (img.startsWith(baseNorm + '/') || img === baseNorm) return img;
  if (img.startsWith('/')) return baseNorm + img;
  return img;
}
---

<section style="padding:42px 0 64px;">
  <div style="max-width:1240px;margin:0 auto;padding:0 20px;">
    <p class="muted" style="font-size:12px;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 8px;">O NÁS</p>
    <h2 style="font-size:28px;margin:0 0 12px;">Kdo stojí za projektem zahraniční apartmány</h2>
    <p class="team-section-intro muted">Naším cílem není jen prodat apartmán u moře, ale pomoci klientům bezpečně diverzifikovat majetek, ochránit úspory před inflací a vytvořit druhý domov v atraktivní destinaci.</p>
    <div class="team-grid" data-count={members.length}>
      {members.map((m) => (
        <a class="focus-ring team-card team-card-link" href={`${basePath}o-projektu/#team-${m.slug}`}>
          <div class="team-photo">
            <img src={getImagePath(m.image)} alt={m.name} width="200" height="250" loading="lazy" decoding="async" />
          </div>
          <div class="team-name">{m.name}</div>
          <div class="team-role">{m.role}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .team-section-intro {
    font-size: 15px;
    line-height: 1.7;
    margin: 0 0 24px;
    max-width: 72ch;
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 14px;
  }
  .team-card {
    text-align: center;
    flex-shrink: 0;
    text-decoration: none;
    color: inherit;
  }
  .team-card:hover {
    text-decoration: none;
  }
  .team-photo {
    aspect-ratio: 4/5;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--c-line);
    margin-bottom: 12px;
  }
  .team-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .team-name {
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--c-ink, #071A2D);
  }
  .team-role {
    font-size: 12px;
    color: var(--c-slate, #4A5568);
    margin-top: 4px;
  }
  /* Mobil: carousel, vždy 2 karty vedle sebe */
  @media (max-width: 900px) {
    .team-grid {
      display: flex;
      grid-template-columns: unset;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      gap: 14px;
      padding-bottom: 8px;
      -webkit-overflow-scrolling: touch;
    }
    .team-card {
      scroll-snap-align: start;
      flex: 0 0 calc(50% - 7px);
      min-width: calc(50% - 7px);
    }
  }
</style>
