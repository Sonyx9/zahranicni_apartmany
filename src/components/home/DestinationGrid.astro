---
type Country = { slug: string; name: string; heroImage?: string; flag?: string; partnerOffersUrl?: string };
type Props = { countries: Country[] };
const { countries } = Astro.props;
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const partnerRel = "noopener nofollow sponsored";

function getImagePath(img: string | undefined) {
  if (!img) {
    return `${basePath}images/hero/ocean-horizon.jpg`;
  }
  if (img.startsWith('/')) {
    return `${basePath}${img.slice(1)}`;
  }
  return img;
}

function getFlagPath(flag: string | undefined) {
  if (!flag) return undefined;
  if (flag.startsWith('/')) return `${basePath}${flag.slice(1)}`;
  return flag;
}
---

<section style="padding:34px 0;">
  <div style="max-width:1240px;margin:0 auto;padding:0 20px;">
    <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;flex-wrap:wrap;">
      <h2 style="font-size:28px;margin:0;">Vyberte si destinaci pro svou nemovitost u moře</h2>
      <a class="focus-ring link-cta" href={`${basePath}destinace/`}>Zobrazit všechny →</a>
    </div>
    <p class="destination-grid-intro muted">Níže najdete prověřené destinace, kde má investice do nemovitosti v zahraničí dlouhodobý smysl.</p>

    <div class="destination-grid">
      {countries.map((c) => {
        const cardHref = c.partnerOffersUrl ?? `${basePath}destinace/${c.slug}/`;
        const isExternal = !!c.partnerOffersUrl;
        const flagSrc = getFlagPath(c.flag);
        return (
          <a
            class="focus-ring destination-card"
            href={cardHref}
            rel={isExternal ? partnerRel : undefined}
          >
            <div class="destination-card-image">
              <img src={getImagePath(c.heroImage)} alt={`Pobřeží – ${c.name}`} width="500" height="320" loading="lazy" decoding="async" />
            </div>
            <div class="destination-card-body">
              <div class="destination-card-title">
                <span>{c.name}</span>
                {flagSrc && (
                  <img src={flagSrc} alt="" width="72" height="52" loading="lazy" decoding="async" class="destination-flag" onerror="this.style.display='none'" />
                )}
              </div>
              <div class="destination-card-cta muted">Zobrazit nabídku →</div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .destination-grid-intro {
    font-size: 15px;
    line-height: 1.6;
    margin: 12px 0 0;
    max-width: 72ch;
  }
  .destination-grid {
    margin-top: 20px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .destination-card {
    border: 1px solid var(--c-line);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: #f0eeea;
    text-decoration: none;
    color: inherit;
  }
  .destination-card:hover {
    border-color: var(--c-gold);
  }
  .destination-card-image {
    aspect-ratio: 16 / 10;
    background: #e5e3df;
    overflow: hidden;
    flex-shrink: 0;
  }
  .destination-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .destination-card-body {
    padding: 18px 18px 20px;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .destination-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    line-height: 1.25;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .destination-flag {
    flex-shrink: 0;
    object-fit: contain;
    width: 72px;
    height: 52px;
  }
  .destination-card-cta {
    margin-top: auto;
    padding-top: 10px;
    font-size: 13px;
  }
  @media (max-width: 1020px) {
    .destination-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 620px) {
    .destination-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
    .destination-card-body {
      padding: 14px 14px 16px;
    }
    .destination-card-title {
      font-size: 16px;
    }
    .destination-flag {
      width: 60px;
      height: 43px;
    }
  }
</style>
