---
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

const tabs = [
  { href: `${basePath}destinace/`, label: "Nejoblíbenější lokality", active: true, icon: "star" },
  { href: "#faq", label: "Nejčastější dotazy", active: false, icon: "help" },
  { href: "https://www.nemovitostbulharsko.cz/category/pruvodce-koupi-nemovitosti-v-bulharsku/", label: "Náš průvodce", active: false, icon: "book" },
];
---

<section class="quick-nav-section" aria-label="Rychlá navigace">
  <div class="quick-nav-inner">
    {tabs.map((tab) => (
      <a href={tab.href} class={`quick-nav-tab ${tab.active ? "quick-nav-tab--active" : ""}`}>
        <span class="quick-nav-icon" aria-hidden="true">
          {tab.icon === "star" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
          )}
          {tab.icon === "help" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
              <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
          )}
          {tab.icon === "book" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
              <line x1="8" y1="6" x2="16" y2="6" />
              <line x1="8" y1="10" x2="16" y2="10" />
            </svg>
          )}
        </span>
        <span class="quick-nav-label">{tab.label}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .quick-nav-section { padding: 0; }
  .quick-nav-inner {
    --quick-nav-bar-height: 104px;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px 0 0;
    background: transparent;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .quick-nav-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 24px 16px;
    text-decoration: none !important;
    color: rgba(255, 255, 255, 0.9);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: background-color 0.2s ease, color 0.2s ease;
    background: #071A2D;
    min-height: 104px;
    box-sizing: border-box;
  }
  .quick-nav-tab:hover { background: #0d2137; color: #fff; text-decoration: none !important; }
  .quick-nav-tab--active { background: #C6A75E; color: #fff; text-decoration: none !important; }
  .quick-nav-tab--active:hover { background: #111111; color: #fff; text-decoration: none !important; }
  .quick-nav-icon { display: flex; align-items: center; justify-content: center; color: inherit; }
  .quick-nav-icon svg { display: block; }
  .quick-nav-label { text-align: center; line-height: 1.3; }
  @media (max-width: 900px) {
    .quick-nav-inner {
      max-width: none;
      margin: 0;
      padding: 0;
    }
  }
  @media (max-width: 600px) {
    .quick-nav-tab { padding: 18px 12px; font-size: 11px; min-height: 82px; }
    .quick-nav-icon svg { width: 22px; height: 22px; }
  }
</style>
