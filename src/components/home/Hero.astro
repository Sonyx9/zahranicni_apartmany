---
import QuickNavTabs from "./QuickNavTabs.astro";
import type { FeaturedPropertiesPayload } from "../../lib/data";

type Props = {
  overTitle?: string;
  title: string;
  subtitle: string;
  ctaHref: string;
  ctaText: string;
  image?: string;
  featuredProperties?: FeaturedPropertiesPayload | null;
};
const { overTitle, title, subtitle, ctaHref, ctaText, featuredProperties = null } = Astro.props;
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const heroBgUrl = `${basePath}images/site/hero-bg.webp`;
const list = featuredProperties?.properties ?? [];
const nextChangeAt = featuredProperties?.nextChangeAt ?? '';
const showFeatured = list.length > 0 && nextChangeAt;
---

<section class="hero-section">
  <div class="hero-bg" aria-hidden="true">
    <img src={heroBgUrl} alt="" width="1920" height="800" fetchpriority="high" decoding="async" />
  </div>
  <div class="hero-inner">
    <div class="hero-content">
      {overTitle && <p class="hero-over-title">{overTitle}</p>}
      <h1>{title}</h1>
      <p class="muted hero-subtitle">{subtitle}</p>
      <a class="focus-ring btn-primary" href={ctaHref} rel={ctaHref.startsWith('http') ? 'nofollow sponsored' : undefined}>
        <span>{ctaText}</span>
        <span aria-hidden="true">→</span>
      </a>
      <div class="hero-meta">
        Osobní zastoupení v 8 zemích · Působíme od roku 2002
      </div>
    </div>
    {showFeatured && (
      <div class="hero-featured-wrap">
        {list.length > 1 && (
          <button type="button" class="hero-featured-arrow hero-featured-arrow-prev" aria-label="Předchozí nabídka" data-carousel-prev>
            <span aria-hidden="true">←</span>
          </button>
        )}
        <aside class="hero-featured" aria-label="Nepropásněte – karusel nabídek">
          <div class="hero-featured-viewport">
            <div
              class="hero-featured-track"
              style={list.length > 1 ? `--slides: ${list.length + 2}; --carousel-index: 1` : `--slides: 1; --carousel-index: 0`}
              data-carousel-track
              data-slides={list.length}
              data-total-slides={list.length > 1 ? list.length + 2 : 1}
            >
              {list.length > 1 ? (
                <>
                  <a class="hero-featured-slide" href={list[list.length - 1].url} rel="noopener noreferrer nofollow sponsored" target="_blank" aria-hidden="true">
                    <span class="hero-featured-stitek">Nepropásněte</span>
                    <div class="hero-featured-image-wrap">
                      {list[list.length - 1].image ? (
                        <img src={list[list.length - 1].image} alt="" width="320" height="200" loading="lazy" />
                      ) : (
                        <div class="hero-featured-placeholder" aria-hidden="true" />
                      )}
                    </div>
                    <div class="hero-featured-body">
                      <h2 class="hero-featured-title">{list[list.length - 1].title}</h2>
                      {list[list.length - 1].price && <p class="hero-featured-price">{list[list.length - 1].price}</p>}
                    </div>
                  </a>
                  {list.map((prop) => (
                    <a class="hero-featured-slide" href={prop.url} rel="noopener noreferrer nofollow sponsored" target="_blank">
                      <span class="hero-featured-stitek">Nepropásněte</span>
                      <div class="hero-featured-image-wrap">
                        {prop.image ? (
                          <img src={prop.image} alt="" width="320" height="200" loading="lazy" />
                        ) : (
                          <div class="hero-featured-placeholder" aria-hidden="true" />
                        )}
                      </div>
                      <div class="hero-featured-body">
                        <h2 class="hero-featured-title">{prop.title}</h2>
                        {prop.price && <p class="hero-featured-price">{prop.price}</p>}
                      </div>
                    </a>
                  ))}
                  <a class="hero-featured-slide" href={list[0].url} rel="noopener noreferrer nofollow sponsored" target="_blank" aria-hidden="true">
                    <span class="hero-featured-stitek">Nepropásněte</span>
                    <div class="hero-featured-image-wrap">
                      {list[0].image ? (
                        <img src={list[0].image} alt="" width="320" height="200" loading="lazy" />
                      ) : (
                        <div class="hero-featured-placeholder" aria-hidden="true" />
                      )}
                    </div>
                    <div class="hero-featured-body">
                      <h2 class="hero-featured-title">{list[0].title}</h2>
                      {list[0].price && <p class="hero-featured-price">{list[0].price}</p>}
                    </div>
                  </a>
                </>
              ) : (
                list.map((prop) => (
                  <a class="hero-featured-slide" href={prop.url} rel="noopener noreferrer nofollow sponsored" target="_blank">
                    <span class="hero-featured-stitek">Nepropásněte</span>
                    <div class="hero-featured-image-wrap">
                      {prop.image ? (
                        <img src={prop.image} alt="" width="320" height="200" loading="lazy" />
                      ) : (
                        <div class="hero-featured-placeholder" aria-hidden="true" />
                      )}
                    </div>
                    <div class="hero-featured-body">
                      <h2 class="hero-featured-title">{prop.title}</h2>
                      {prop.price && <p class="hero-featured-price">{prop.price}</p>}
                    </div>
                  </a>
                ))
              )}
            </div>
          </div>
          <div class="hero-featured-meta">
            <span class="hero-featured-locality">Lokalita: KYPR</span>
            <p class="hero-featured-countdown" id="hero-featured-countdown" data-next-change-at={nextChangeAt} aria-live="polite">
              <span class="hero-featured-countdown-label">Nabídka vyprší za </span>
              <span class="hero-featured-countdown-value">—</span>
            </p>
          </div>
        </aside>
        {list.length > 1 && (
          <button type="button" class="hero-featured-arrow hero-featured-arrow-next" aria-label="Další nabídka" data-carousel-next>
            <span aria-hidden="true">→</span>
          </button>
        )}
      </div>
    )}
  </div>
  <div class="hero-quicknav">
    <QuickNavTabs />
  </div>
</section>
<script is:inline>
  (function () {
    var CAROUSEL_INTERVAL_MS = 4000;
    var countdownStarted = false;

    function runCountdown() {
      if (countdownStarted) return;
      var el = document.getElementById('hero-featured-countdown') || document.querySelector('[data-next-change-at]');
      if (!el) return;
      var valueEl = el.querySelector('.hero-featured-countdown-value') || el.querySelector('span:last-child');
      if (!valueEl) return;
      countdownStarted = true;
      /** Cílová hodina v UTC – 1:00 UTC = 2:00 SEČ */
      var TARGET_HOUR_UTC = 1;
      function tick() {
        try {
          var now = new Date();
          var end = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate(), TARGET_HOUR_UTC, 0, 0, 0));
          if (end.getTime() <= now.getTime()) {
            end.setUTCDate(end.getUTCDate() + 1);
          }
          var d = end.getTime() - now.getTime();
          var h = Math.floor(d / (1000 * 60 * 60));
          var m = Math.floor((d % (1000 * 60 * 60)) / (1000 * 60));
          valueEl.textContent = h + ' h ' + m + ' min';
        } catch (e) {}
      }
      tick();
      setInterval(tick, 1000);
    }

    function tryCountdown(attempt) {
      attempt = attempt || 0;
      runCountdown();
      if (!countdownStarted && attempt < 20) setTimeout(function () { tryCountdown(attempt + 1); }, 150);
    }

    function runCarousel() {
      var track = document.querySelector('[data-carousel-track]');
      var prevBtn = document.querySelector('[data-carousel-prev]');
      var nextBtn = document.querySelector('[data-carousel-next]');
      var realCount = track ? parseInt(track.getAttribute('data-slides'), 10) || 1 : 0;
      var totalSlides = track ? parseInt(track.getAttribute('data-total-slides'), 10) || realCount : 0;
      if (realCount <= 1) return;
      var index = 1;
      var isJumping = false;

      function applyIndex() {
        if (track) track.style.setProperty('--carousel-index', String(index));
      }

      function jumpTo(pos) {
        isJumping = true;
        if (track) track.style.transition = 'none';
        index = pos;
        applyIndex();
        if (track) track.offsetHeight;
        if (track) track.style.transition = '';
        setTimeout(function () { isJumping = false; }, 50);
      }

      function onTransitionEnd() {
        if (isJumping) return;
        if (index === totalSlides - 1) {
          jumpTo(1);
        } else if (index === 0) {
          jumpTo(realCount);
        }
      }

      if (track) track.addEventListener('transitionend', onTransitionEnd);

      function goNext() {
        if (isJumping) return;
        if (index + 1 >= totalSlides) {
          jumpTo(1);
          return;
        }
        index = index + 1;
        applyIndex();
      }
      function goPrev() {
        if (isJumping) return;
        if (index - 1 < 0) {
          jumpTo(realCount);
          return;
        }
        index = index - 1;
        applyIndex();
      }

      setInterval(goNext, CAROUSEL_INTERVAL_MS);
      if (prevBtn) prevBtn.addEventListener('click', goPrev);
      if (nextBtn) nextBtn.addEventListener('click', goNext);
    }

    function run() {
      tryCountdown();
      runCarousel();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      setTimeout(run, 0);
    }
  })();
</script>

<style>
  .hero-section {
    position: relative;
    overflow: hidden;
    min-height: 840px;
    padding: 96px 0 0;
    display: flex;
    align-items: center;
  }
  @media (min-width: 901px) {
    .hero-section {
      min-height: 760px;
      padding: 112px 0 0;
    }
  }
  .hero-quicknav {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(245, 242, 234, 0.72) 0%, rgba(245, 242, 234, 0.92) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
    transform: translateY(-104px);
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
  }
  .hero-content {
    flex: 1 1 400px;
    min-width: 0;
  }
  .hero-featured-wrap {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    max-width: 416px;
  }
  .hero-featured {
    flex: 1 1 auto;
    min-width: 0;
    max-width: 320px;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12), 0 4px 12px rgba(0, 0, 0, 0.08), 0 2px 4px rgba(0, 0, 0, 0.04);
    background: #f5f2ea;
  }
  .hero-featured-arrow {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: linear-gradient(135deg, #c9a227 0%, #b8860b 100%);
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .hero-featured-arrow:hover {
    background: linear-gradient(135deg, #b8860b 0%, #8b6914 100%);
    color: #fff;
  }
  .hero-featured-meta {
    padding: 10px 16px 14px;
  }
  .hero-featured-locality {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--slate, #64748b);
    margin-bottom: 4px;
  }
  .hero-featured-countdown {
    font-size: 12px;
    color: #b91c1c;
    margin: 0;
    padding: 0;
  }
  .hero-featured-viewport {
    overflow: hidden;
    border-radius: 10px;
  }
  .hero-featured-track {
    display: flex;
    width: calc(var(--slides, 1) * 100%);
    transition: transform 0.35s ease-out;
    transform: translateX(calc(-100% * var(--carousel-index, 0) / var(--slides, 1)));
  }
  .hero-featured-slide {
    flex: 0 0 calc(100% / var(--slides, 1));
    width: calc(100% / var(--slides, 1));
    min-width: 0;
    box-sizing: border-box;
    color: inherit;
    text-decoration: none;
    display: block;
    position: relative;
  }
  .hero-featured-slide:hover {
    color: var(--link-hover, #0a5);
    text-decoration: none;
  }
  .hero-featured-image-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--slate);
  }
  .hero-featured-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-featured-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8e4dc 0%, #d4cfc4 100%);
  }
  .hero-featured-body {
    padding: 14px 16px 18px;
    background: #f5f2ea;
  }
  .hero-featured-stitek {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 1;
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #fff;
    padding: 4px 10px;
    border-radius: 6px;
    background: linear-gradient(135deg, #c9a227 0%, #b8860b 100%);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }
  .hero-featured-countdown-value {
    font-weight: 600;
    color: #b91c1c;
  }
  .hero-featured-title {
    font-size: 15px;
    line-height: 1.4;
    margin: 0 0 4px;
    font-weight: 600;
    color: #111;
  }
  .hero-featured-price {
    font-size: 15px;
    font-weight: 700;
    color: #15803d;
    margin: 0;
  }
  @media (min-width: 900px) {
    .hero-featured-wrap {
      margin-top: 0;
    }
  }
  .hero-over-title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--slate, #64748b);
    margin: 0 0 10px;
  }
  .hero-inner h1 {
    font-size: 44px;
    line-height: 1.05;
    margin: 0 0 14px;
  }
  .hero-subtitle {
    font-size: 18px;
    line-height: 1.75;
    margin: 0 0 20px;
    max-width: 58ch;
  }
  .hero-meta {
    margin-top: 18px;
    font-size: 12px;
    line-height: 1.5;
    font-weight: 600;
    color: var(--slate);
  }
  @media (max-width: 600px) {
    .hero-inner h1 {
      font-size: 32px;
    }
  }
  /* Mobilní úpravy až na konci, aby přepsaly základní pravidla */
  @media (max-width: 900px) {
    .hero-section {
      padding-top: 72px;
    }
    .hero-inner {
      transform: none;
    }
    .hero-featured-wrap {
      display: none !important;
    }
  }
</style>
