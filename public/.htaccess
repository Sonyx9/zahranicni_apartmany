# Cache static assets (Apache)
# Aktivní pouze na serveru s Apache a povoleným mod_headers

<IfModule mod_headers.c>
  # Buildované assety (hash v názvu = immutable)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Obrázky
  <FilesMatch "\.(webp|png|jpg|jpeg|gif|ico|svg)$">
    Header set Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
  </FilesMatch>
  # Složka assets (Astro build output)
  <If "%{REQUEST_URI} =~ m#^/assets/#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>
</IfModule>
